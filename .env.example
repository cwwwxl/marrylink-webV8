# MarryLink Docker 环境变量配置示例
# 复制此文件为 .env 并修改相应配置

# ==================== 版本 ====================
VERSION=latest

# ==================== MySQL 配置（外部服务） ====================
MYSQL_HOST=host.docker.internal
MYSQL_PORT=3306
MYSQL_DATABASE=marrylink
MYSQL_USER=marrylink
MYSQL_PASSWORD=marrylink123

# ==================== Redis 配置（外部服务） ====================
REDIS_HOST=host.docker.internal
REDIS_PORT=6379
REDIS_PASSWORD=marrylink123

# ==================== 后端配置 ====================
BACKEND_PORT=8080
JWT_SECRET=marrylink-admin-secret-key-2024-for-jwt-token-signing-must-be-at-least-256-bits-change-in-production
JWT_EXPIRATION=86400000
JAVA_OPTS=-Xms512m -Xmx1024m -XX:+UseG1GC

# ==================== 管理后台前端配置 ====================
FRONTEND_PORT=3000

# ==================== 移动端 H5 配置 ====================
MOBILE_PORT=80