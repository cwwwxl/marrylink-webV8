# MarryLink Docker 环境变量配置

# ==================== 版本 ====================
VERSION=latest

# ==================== MySQL 配置（本机服务） ====================
# Linux 服务器上 host.docker.internal 不可用，使用宿主机实际IP或容器名
# 如果 MySQL 也是 Docker 容器，填写容器名；如果是宿主机服务，填写宿主机IP
MYSQL_HOST=host.docker.internal
MYSQL_PORT=3306
MYSQL_DATABASE=marrylink
MYSQL_USER=root
MYSQL_PASSWORD=123456

# ==================== Redis 配置（通过宿主机访问） ====================
# 使用宿主机网关 IP + 宿主机映射端口访问 Redis
# 宿主机网关 IP 通过 docker network inspect hunli_marrylink-network | grep Gateway 获取
REDIS_HOST=redis-6378
REDIS_PORT=6378
REDIS_PASSWORD=Qm8%k!s3

# ==================== 后端配置 ====================
BACKEND_PORT=8080
DEBUG_PORT=5005
JWT_SECRET=marrylink-admin-secret-key-2024-for-jwt-token-signing-must-be-at-least-256-bits-change-in-production
JWT_EXPIRATION=86400000
JAVA_OPTS=-Xms512m -Xmx1024m -XX:+UseG1GC -agentlib:jdwp=transport=dt_socket,server=y,suspend=n,address=*:5005

# ==================== 管理后台前端配置 ====================
FRONTEND_PORT=3000

# ==================== 移动端 H5 配置 ====================
MOBILE_PORT=80