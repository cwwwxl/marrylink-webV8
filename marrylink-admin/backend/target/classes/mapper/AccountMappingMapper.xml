<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.marrylink.mapper.AccountMappingMapper">
    
    <resultMap id="BaseResultMap" type="com.marrylink.entity.AccountMapping">
        <id column="id" property="id"/>
        <result column="account_id" property="accountId"/>
        <result column="user_type" property="userType"/>
        <result column="ref_id" property="refId"/>
        <result column="password" property="password"/>
        <result column="status" property="status"/>
        <result column="last_login_time" property="lastLoginTime"/>
        <result column="create_time" property="createTime"/>
        <result column="update_time" property="updateTime"/>
        <result column="is_deleted" property="isDeleted"/>
    </resultMap>
    
    <select id="selectByAccountAndType" resultMap="BaseResultMap">
        SELECT * FROM account_mapping
        WHERE account_id = #{accountId}
        AND user_type = #{userType}
        AND is_deleted = 0
    </select>
    
</mapper>